{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "host": "127.0.0.1",
      "port": 17099
    },
    "firestore": {
      "host": "127.0.0.1",
      "port": 17080,
      "websocketPort": 17150
    },
    "storage": {
      "host": "127.0.0.1",
      "port": 17199
    },
    "hosting": {
      "host": "127.0.0.1",
      "port": 17000
    },
    "ui": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 17400
    },
    "hub": {
      "host": "127.0.0.1",
      "port": 17440
    },
    "logging": {
      "host": "127.0.0.1",
      "port": 17450
    },
    "singleProjectMode": true
  }
}
