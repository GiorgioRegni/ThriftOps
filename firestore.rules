rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return signedIn() && exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid));
    }

    function memberRole(orgId) {
      return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data.role;
    }

    // Deny all by default. Firestore is only a lightweight authorization mirror
    // for Firebase Storage; Supabase Postgres is authoritative for domain data.
    match /{document=**} {
      allow read, write: if false;
    }

    match /orgs/{orgId} {
      // The backend writes these mirror docs through Firebase Admin.
      allow read: if isOrgMember(orgId);
      allow write: if false;

      match /members/{uid} {
        allow read: if isOrgMember(orgId) || (signedIn() && uid == request.auth.uid);
        allow write: if false;
      }
    }
  }
}
